Vagrant.configure("2") do |config|
  config.vm.box = "shk/centos-stream-9-arm64"
  config.vm.network "private_network", ip: "192.168.56.16"
  config.vm.network "public_network"

  config.vm.provision "shell", inline: <<-SHELL
    yum install httpd wget unzip git -y
    # Shared directory used as a convention across all DevOps lab VMs for storing scripts and configs
    mkdir /opt/devopsdir
    # Print memory and uptime on first boot as a quick sanity check that the VM is healthy
    free -m
    uptime
  SHELL
end
